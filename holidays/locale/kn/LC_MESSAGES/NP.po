#. %s (estimated).
#, c-format
msgid "%s (अनुमानित)"
msgstr "%s (ಅಂದಾಜು)"

#. Martyr's Day.
msgid "शहीद दिवस"
msgstr "ಹುತಾತ್ಮರ ದಿನ"

#. National Democracy Day.
msgid "राष्ट्रिय प्रजातन्त्र दिवस"
msgstr "ರಾಷ್ಟ್ರೀಯ ಪ್ರಜಾಪ್ರಭುತ್ವ ದಿನ"

#. Republic Day.
msgid "गणतन्त्र दिवस"
msgstr "ಗಣರಾಜ್ಯ ದಿನ"

#. Ram Navami.
msgid "राम नवमी"
msgstr "ರಾಮ ನವಮಿ"

#. Janai Poornima.
msgid "जनै पूर्णिमा"
msgstr "ಜನೈ ಪೂರ್ಣಿಮಾ"

#. Shree Krishna Janmashtami.
msgid "श्रीकृष्ण जन्माष्टमी"
msgstr "ಶ್ರೀಕೃಷ್ಣ ಜನ್ಮಾಷ್ಟಮಿ"

#. Ghatasthapana.
msgid "घटस्थापना"
msgstr "ಘಟಸ್ಥಾಪನಾ"

#. Duwadashi (Dashain).
msgid "दुवादशी (दशैं)"
msgstr "ದ್ವಾದಶಿ (ದಸರಾ)"

#. Prithvi Jayanti.
msgid "पृथ्वी जयन्ती"
msgstr "ಪೃಥ್ವಿ ಜಯಂತಿ"

#. International Women's Day.
msgid "अन्तर्राष्ट्रिय महिला दिवस"
msgstr "ಅಂತರರಾಷ್ಟ್ರೀಯ ಮಹಿಳಾ ದಿನ"

#. Nepali New Year.
msgid "नेपाली नयाँ वर्ष"
msgstr "ನೇಪಾಳಿ ಹೊಸ ವರ್ಷ"

#. International Labor Day.
msgid "अन्तर्राष्ट्रिय श्रम दिवस"
msgstr "ಅಂತರರಾಷ್ಟ್ರೀಯ ಕಾರ್ಮಿಕ ದಿನ"

#. Constitution Day.
msgid "संविधान दिवस"
msgstr "ಸಂವಿಧಾನ ದಿನ"

#. Christmas Day.
msgid "क्रिसमसको दिन"
msgstr "ಕ್ರಿಸ್ಮಸ್ ದಿನ"

#. Maghe Sankranti.
msgid "माघे संक्रान्ति"
msgstr "ಮಾಘ ಸಂಕ್ರಾಂತಿ"

#. Sonam Lhochhar.
msgid "सोनम ल्होछार"
msgstr "ಸೋನಮ್ ಲ್ಹೋಛಾರ್"

#. Maha Shivaratri.
msgid "महाशिवरात्रि"
msgstr "ಮಹಾಶಿವರಾತ್ರಿ"

#. Gyalpo Lhosar.
msgid "ग्याल्पो ल्होसार"
msgstr "ಗ್ಯಾಲ್ಪೊ ಲ್ಹೋಸಾರ್"

#. Fagu Poornima.
msgid "फागुपूर्णिमा"
msgstr "ಫಾಗು ಹುಣ್ಣಿಮೆ"

#. Fagu Poornima (Terai).
msgid "फागुपूर्णिमा (तराई)"
msgstr "ಫಾಗು ಹುಣ್ಣಿಮೆ (ತರಾಯಿ)"

#. Buddha Jayanti.
msgid "बुद्ध जयन्ती"
msgstr "ಬುದ್ಧ ಜಯಂತಿ"

#. Fulpati.
msgid "फुलपाती"
msgstr "ಫುಲ್ಪಾತಿ"

#. Maha Ashtami.
msgid "महा अष्टमी"
msgstr "ಮಹಾ ಅಷ್ಟಮಿ"

#. Maha Navami.
msgid "महा नवमी"
msgstr "ಮಹಾ ನವಮಿ"

#. Bijaya Dashami.
msgid "विजया दशमी"
msgstr "ವಿಜಯ ದಶಮಿ"

#. Ekadashi (Dashain).
msgid "एकादशी (दशैं)"
msgstr "ಏಕಾದಶಿ (ದಸರಾ)"

#. Laxmi Pooja.
msgid "लक्ष्मीपूजा"
msgstr "ಲಕ್ಷ್ಮಿ ಪೂಜೆ"

#. Gai Tihar.
msgid "गाई तिहार"
msgstr "ಗೋ ತಿಹಾರ್"

#. Gobardhan Pooja.
msgid "गोवर्धन पूजा"
msgstr "ಗೋವರ್ಧನ ಪೂಜೆ"

#. Mha Pooja.
msgid "म्ह पूजा"
msgstr "ಮ್ಹಾ ಪೂಜೆ"

#. Bhai Tika.
msgid "भाइटीका"
msgstr "ಭಾಯಿ ತಿಕಾ"

#. Chhath Parva.
msgid "छठ पर्व"
msgstr "ಛತ್ ಹಬ್ಬ"

#. Tamu Lhochhar.
msgid "तमु ल्हाेसार"
msgstr "ತಾಮು ಲ್ಹೋಸಾರ್"

#. Eid al-Fitr.
msgid "ईद (ईद उल फित्र)"
msgstr "ಈದ್ ಅಲ್-ಫಿತರ್"

#. Eid al-Adha.
msgid "बकर ईद (ईद उल अजहा)"
msgstr "ಈದ್ ಅಲ್-ಅಧಾ"

#. Day of National Mourning.
msgid "राष्ट्रिय शोक दिवस"
msgstr "ರಾಷ್ಟ್ರೀಯ ಶೋಕ ದಿನ"

#. Tihar Holiday.
msgid "तिहार बिदा"
msgstr "ತಿಹಾರ್ ರಜೆ"

#. People War's Day.
msgid "जनयुद्ध दिवस"
msgstr "ಜನಯುದ್ಧ ದಿನ"
