#. %s (estimated).
#, c-format
msgid "%s (ཚོད་དཔག་གི།)"
msgstr ""

#. Birth Anniversary of His Majesty the King.
msgid "ཟླཝ་བཅུ་གཉིས་པའི་ཚེས་ ༢༤ ལས་ ༢༥ ཚུན་ མི་དབང་མངའ་བདག་རིན་པོ་ཆེའི་འཁྲུངས་སྐར་དུས་སྟོན་ངལ་གསོ།"
msgstr ""

#. Birth Anniversary of the 3rd Druk Gyalpo.
msgid "ཟླཝ་གསུམ་པའི་ཚེས་ ༥ ལུ་ མི་དབང་འབྲུག་རྒྱལ་གསུམ་པའི་འཁྲུངས་སྐར་དུས་སྟོན་ངལ་གསོ།"
msgstr ""

#. Coronation of His Majesty the King.
msgid "ཟླཝ་དགུ་པའི་ཚེས་ ༡༡ ལུ་ མི་དབང་མངའ་བདག་རིན་པོ་ཆེའི་གསེར་ཁྲི་མངའ་གསོལ་གྱིས་དུས་སྟོན་ངལ་གསོ།"
msgstr ""

#. Birth Anniversary of the 4th Druk Gyalpo - Constitution Day.
msgid "ཟླཝ་དགུ་པའི་ཚེས་ ༢༢ ལུ་ མི་དབང་འབྲུག་རྒྱལ་བཞི་པའི་འཁྲུངས་སྐར་དུས་སྟོན་ངལ་གསོ།"
msgstr ""

#. National Day.
msgid "ཟླཝ་བཅུ་པའི་ཚེས་ ༢༨ ལུ་ བརྒྱུད་འཛིན་གྱིས་རྒྱལ་སྲིད་ཐོག་མ་དབུ་བརྙེས་པའི་རྒྱལ་ཡོངས་དུས་ཆེན་གྱི་ངལ་གསོ།"
msgstr ""

#. Winter Solstice.
msgid "ཟླཝ་བཅུ་གཅིག་པའི་ཚེས་ ༠༣ ལུ་ དགུན་ཉི་ལྡོག་གི་ངལ་གསོ།"
msgstr ""

#. Traditional Day of Offering.
msgid "ཟླཝ་བཅུ་གཉིས་པའི་ཚེས་ ༠༡ ལུ་ སྔར་སྲོལ་འབུལ་བའི་ལོ་གསར་གྱི་ངལ་གསོ།"
msgstr ""

#. Losar.
msgid "ཟླཝ་དང་པའི་ཚེས་ ༠༡ དང་ ༢ ལུ་ གནམ་ལོ་གསར་ཚེས་ཀྱིས་དུས་སྟོན་ངལ་གསོ།"
msgstr ""

#. Death Anniversary of Zhabdrung.
msgid "ཟླཝ་གསུམ་པའི་ཚེས་ ༡༠ ལུ་ མཐུ་ཆེན་བདུད་འཇོམས་རྡོ་རྗེ་དགོངས་རྫོགས་དུས་དྲན་ངལ་གསོ། ༼ཞབས་དྲུང་སྐུ་མཆོད༽"
msgstr ""

#. Lord Buddha's Parinirvana.
msgid "ཟླཝ་བཞི་པའི་ཚེས་ ༡༥ ལུ་ སངས་རྒྱས་བཅོམ་ལྡན་འདས་ཀྱི་དུས་ཆེན་ལྔ་འཛོམས་ངལ་གསོ།"
msgstr ""

#. Birth Anniversary of Guru Rinpoche.
msgid "ཟླཝ་ལྔ་པའི་ཚེས་ ༡༠ ལུ་ ཨོ་རྒྱན་གུ་རུ་རིན་པོ་ཆེའི་འཁྲུངས་སྐར་དུས་ཆེན་ངལ་གསོ།"
msgstr ""

#. First Sermon of Lord Buddha.
msgid "ཟླཝ་དྲུག་པའི་ཚེས་ ༤ ལུ་ སྟོན་པ་མཆོག་ཝ་ར་ན་སིར་བདེན་བཞིའི་ཆོས་འཁོར་བསྐོར་བའི་དུས་ཆེན་ངལ་གསོ།"
msgstr ""

#. Blessed Rainy Day.
msgid "ཟླཝ་བརྒྱད་པའི་ཚེས་ ༢ ལུ་ རྒྱལ་ཡོངས་ཁྲུས་བབས་ཀྱི་ངལ་གསོ།"
msgstr ""

#. Dassain.
msgid "ཟླཝ་བརྒྱད་པའི་ཚེས་ ༡༠ ལུ་ ལྷོ་མཚམས་ད་སའིན་ཀྱི་ངལ་གསོ།"
msgstr ""

#. Descending Day of Lord Buddha.
msgid "ཟླཝ་དགུ་པའི་ཚེས་ ༢༢ ལུ་ རྒྱལ་བ་ལྷ་ལས་བབས་པའི་དུས་ཆེན་ངལ་གསོ།"
msgstr ""

#. Thimphu Drubchoe.
msgid "ཟླཝ་བརྒྱད་པའི་ཚེས་ ༦ ལུ་ ཐིམ་རྫོང་ལྷ་མོ་གཙོ་མོའི་དངོས་འཆམ་མཇལ་རྒྱུའི་ངལ་གསོ། ༼ཐིམ་ཕུག་ལུ་རྐྱངམ་ཅིག༽"
msgstr ""

#. Thimphu Tshechu.
msgid "ཟླཝ་བརྒྱད་པའི་ཚེས་ ༡༠-༡༢ ཚུན་ ཐིམ་ཕུ་ཚེས་བཅུའི་ངལ་གསོ། ༼ཐིམ་ཕུ་ལུ་རྐྱངམ་ཅིག༽"
msgstr ""
