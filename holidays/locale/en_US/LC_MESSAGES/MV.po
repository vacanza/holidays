#. %s (estimated).
#, c-format
msgid "%s (އަންދާޒާކުރި)"
msgstr "%s (estimated)"

#. New Year's Day.
msgid "މީލާދީ އާ އަހަރު ފެށޭ ދުވަސް"
msgstr "New Year's Day"

#. Labor Day.
msgid "ބައިނަލްއަޤްވާމީ މަސައްކަތްތެރިންގެ ދުވަސް"
msgstr "Labor Day"

#. Independence Day.
msgid "މިނިވަން ދުވަސް"
msgstr "Independence Day"

#. Victory Day.
msgid "ނަޞްރުގެ ދުވަސް"
msgstr "Victory Day"

#. Republic Day.
msgid "ޖުމްހޫރީ ދުވަސް"
msgstr "Republic Day"

#. First Day of Ramadan.
msgid "ރަމަޟާން މަސް ފެށޭ ދުވަސް"
msgstr "Beginning of Ramadan"

#. Eid al-Fitr Holiday.
msgid "ފިޠުރުޢީދު ދުވަސް"
msgstr "Eid al-Fitr"

#. Eid al-Fitr Holiday (Day 2).
msgid "ފިޠުރުޢީދުގެ މުނާސަބަތުގައި"
msgstr "Eid al-Fitr"

#. Arafat Day.
msgid "ޙައްޖުދުވަސް"
msgstr "Hajj Day"

#. Eid al-Adha Holiday.
msgid "އަޟްޙާޢީދު ދުވަސް"
msgstr "Eid al-Adha"

#. Eid al-Adha Holiday (Day 2).
msgid "އަޟްޙާޢީދުގެ މުނާސަބަތުގައި"
msgstr "Eid al-Adha"

#. Islamic New Year.
msgid "ހިޖުރީ އާ އަހަރު ފެށޭ ދުވަސް"
msgstr "Islamic New Year"

#. National Day.
msgid "ޤައުމީ ދުވަސް"
msgstr "National Day"

#. Prophet's Birthday.
msgid "ކީރިތި ރަސޫލާގެ ޢީދުމީލާދު"
msgstr "Mawlid al-Nabi"

#. The Day Maldives Embraced Islam.
msgid "ރާއްޖެ އިސްލާމްވީ ދުވަސް"
msgstr "The Day Maldives Embraced Islam"
