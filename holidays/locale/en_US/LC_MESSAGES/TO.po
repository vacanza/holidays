#. %s (observed).
#, c-format
msgid "%s (fakatokangaʻi)"
msgstr "%s (observed)"

#. New Year's Day.
msgid "ʻUluaki ʻAho ʻo e Taʻu Foʻou"
msgstr "New Year's Day"

#. Birthday of the Reigning Sovereign of Tonga.
msgid "ʻAho ʻAloʻi ʻo ʻEne ʻAfio ko e Tuʻi ʻo Tonga ʻoku lolotonga Pule"
msgstr "Birthday of the Reigning Sovereign of Tonga"

#. Birthday of the Heir to the Crown of Tonga.
msgid "ʻAho ʻAloʻi ʻo e ʻEa ki he Kalauni ʻo Tonga"
msgstr "Birthday of the Heir to the Crown of Tonga"

#. Good Friday.
msgid "Falaite Lelei"
msgstr "Good Friday"

#. Easter Monday.
msgid "Monite ʻo e Toetuʻu"
msgstr "Easter Monday"

#. Anzac Day.
msgid "ʻAho Anzac"
msgstr "Anzac Day"

#. Emancipation Day.
msgid "ʻAho Tauʻataina"
msgstr "Emancipation Day"

#. Anniversary of the Coronation Day of the reigning Sovereign of Tonga.
msgid "Fakamanatu ʻo e ʻAho Hilifaki Kalauni ʻo ʻEne ʻAfio ko e Tuʻi ʻo Tonga ʻa ia ʻoku lolotonga Pule"
msgstr "Anniversary of the Coronation Day of the reigning Sovereign of Tonga"

#. Constitution Day.
msgid "ʻAho Konisitutone"
msgstr "Constitution Day"

#. Anniversary of the Coronation of HM King George Tupou I.
msgid "ʻAho Fakamanatu ʻo e Hilifaki Kalauni ʻo ʻEne ʻAfio ko Siaosi Tupou I"
msgstr "Anniversary of the Coronation of HM King George Tupou I"

#. Christmas Day.
msgid "ʻAho Kilisimasi"
msgstr "Christmas Day"

#. Boxing Day.
msgid "ʻAho 2 ʻo e Kilisimasi"
msgstr "Boxing Day"

#. Tonga Rugby Public Holiday.
msgid "ʻAho malolo ʻakapulu ʻa Tonga"
msgstr "Tonga Rugby Public Holiday"

#. State Funeral of Akilisi Pohiva.
msgid "Meʻafakaʻeiki ʻo e Siteiti ʻAkilisi Pōhiva"
msgstr "State Funeral of Akilisi Pohiva"
