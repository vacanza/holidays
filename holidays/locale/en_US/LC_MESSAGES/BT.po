#. %s (estimated).
#, c-format
msgid "%s (ཚོད་དཔག་གི།)"
msgstr "%s (estimated)"

#. Birth Anniversary of His Majesty the King.
msgid "རྒྱལ་པོ་མཆོག་གི་སྐུ་འཁྲུངས་དུས་ཆེན།"
msgstr "Birth Anniversary of His Majesty the King"

#. Birth Anniversary of the 3rd Druk Gyalpo.
msgid "འབྲུག་རྒྱལ་པོ་གསུམ་པའི་སྐུ་འཁྲུངས་དུས་ཆེན།"
msgstr "Birth Anniversary of the 3rd Druk Gyalpo"

#. Coronation of His Majesty the King.
msgid "རྒྱལ་པོ་མཆོག་གི་ཁྲི་འདོན་དུས་ཆེན།"
msgstr "Coronation of His Majesty the King"

#.  Birth Anniversary of the 4th Druk Gyalpo - Constitution Day..
msgid "འབྲུག་རྒྱལ་པོ་བཞི་པའི་སྐུ་འཁྲུངས་དུས་ཆེན་– རྩ་ཁྲིམས་ཀྱི་ཉིན།"
msgstr "Birth Anniversary of the 4th Druk Gyalpo - Constitution Day"

#. National Day.
msgid "རྒྱལ་ཡོངས་ཀྱི་ཉིན།"
msgstr "National Day"

#. Winter Solstice.
msgid "དགུན་གྱི་ཉི་མ་ཐུང་ཤོས།"
msgstr "Winter Solstice"

#. Traditional Day of Offering.
msgid "ལུགས་སྲོལ་གྱི་མཆོད་པའི་ཉིན།"
msgstr "Traditional Day of Offering"

#. Losar.
msgid "ལོ་གསར།"
msgstr "Losar"

#. Death Anniversary of Zhabdrung.
msgid "ཞབས་དྲུང་གི་སྐུ་འདས་དུས་ཆེན།"
msgstr "Death Anniversary of Zhabdrung"

#. Lord Buddha's Parinirvana.
msgid "སངས་རྒྱས་ཀྱི་མྱང་འདས།"
msgstr "Lord Buddha's Parinirvana"

#. Birth Anniversary of Guru Rinpoche.
msgid "གུ་རུ་རིན་པོ་ཆེའི་སྐུ་འཁྲུངས་དུས་ཆེན།"
msgstr "Birth Anniversary of Guru Rinpoche"

#. First Sermon of Lord Buddha.
msgid "སངས་རྒྱས་ཀྱི་ཆོས་འཁོར་དང་པོ།"
msgstr "First Sermon of Lord Buddha"

#. Blessed Rainy Day.
msgid "བཀྲ་ཤིས་ཆར་པའི་ཉིན།"
msgstr "Blessed Rainy Day"

#. Dassain.
msgid "ད་སེན།"
msgstr "Dassain"

#. Descending Day of Lord Buddha.
msgid "སངས་རྒྱས་ཀྱི་ལྷ་བབས་དུས་ཆེན།"
msgstr "Descending Day of Lord Buddha"

#. Thimphu Drubchoe.
msgid "ཐིམ་ཕུའི་སྒྲུབ་ཆོད།"
msgstr "Thimphu Drubchoe"

#. Thimphu Tshechu.
msgid "ཐིམ་ཕུའི་ཚེས་བཅུ།"
msgstr "Thimphu Tshechu"
