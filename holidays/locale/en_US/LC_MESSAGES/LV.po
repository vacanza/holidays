#. %s (observed).
#, c-format
msgid "%s (brīvdiena)"
msgstr "%s (observed)"

#. New Year's Day.
msgid "Jaungada diena"
msgstr "New Year's Day"

#. Good Friday.
msgid "Lielā Piektdiena"
msgstr "Good Friday"

#. Easter Sunday.
msgid "Pirmās Lieldienas"
msgstr "Easter Sunday"

#. Easter Monday.
msgid "Otrās Lieldienas"
msgstr "Easter Monday"

#. Labor Day.
msgid "Darba svētki"
msgstr "Labor Day"

#. Constitutional Assembly Convocation Day.
msgid "Latvijas Republikas Satversmes sapulces sasaukšanas diena"
msgstr "Constitutional Assembly Convocation Day"

#. Restoration of Independence Day.
msgid "Latvijas Republikas Neatkarības atjaunošanas diena"
msgstr "Restoration of Independence Day"

#. Proclamation of Declaration of Independence Day.
msgid "Latvijas Republikas Neatkarības deklarācijas pasludināšanas diena"
msgstr "Proclamation of Declaration of Independence Day"

#. Mother's Day.
msgid "Mātes diena"
msgstr "Mother's Day"

#. Whit Sunday.
msgid "Vasarsvētki"
msgstr "Whit Sunday"

#. Midsummer Eve.
msgid "Līgo diena"
msgstr "Midsummer Eve"

#. Midsummer Day.
msgid "Jāņu diena"
msgstr "Midsummer Day"

#. Republic of Latvia Proclamation Day.
msgid "Latvijas Republikas Proklamēšanas diena"
msgstr "Republic of Latvia Proclamation Day"

#. Christmas Eve.
msgid "Ziemassvētku vakars"
msgstr "Christmas Eve"

#. Christmas Day.
msgid "Pirmie Ziemassvētki"
msgstr "Christmas Day"

#. Second Day of Christmas.
msgid "Otrie Ziemassvētki"
msgstr "Second Day of Christmas"

#. New Year's Eve.
msgid "Vecgada diena"
msgstr "New Year's Eve"

#. Substituted date format.
msgid "%d.%m.%Y"
msgstr "%m/%d/%Y"

#. Day off (substituted from %s).
#, c-format
msgid "Brīvdiena (pārcelta no %s)"
msgstr "Day off (substituted from %s)"

#. Nationwide Latvian Song and Dance Celebration Final Day.
msgid "Vispārējo latviešu Dziesmu un deju svētku noslēguma diena"
msgstr "Nationwide Latvian Song and Dance Celebration Final Day"

#. Day of the Pastoral Visit of His Holiness Pope Francis to Latvia.
msgid "Viņa Svētības pāvesta Franciska pastorālās vizītes Latvijā diena"
msgstr "Day of the Pastoral Visit of His Holiness Pope Francis to Latvia"

#. Day of the Latvian Ice Hockey Team's Bronze Medal Win at the 2023 IIHF World Championship.
msgid ""
"Diena, kad Latvijas hokeja komanda ieguva bronzas medaļu 2023. gada Pasaules hokeja čempionātā"
msgstr "Day of the Latvian Ice Hockey Team's Bronze Medal Win at the 2023 IIHF World Championship"
