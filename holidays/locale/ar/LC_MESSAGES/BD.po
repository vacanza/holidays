#. Martyrs' Day and International Mother Language Day.
msgid "শহীদ দিবস ও আন্তর্জাতিক মাতৃভাষা দিবস"
msgstr "يوم الشهداء واليوم الدولي للغة الأم"

#. Sheikh Mujibur Rahman's Birthday.
msgid "জাতির পিতা বঙ্গবন্ধু শেখ মুজিবুর রহমান এর জন্মদিবস"
msgstr "عيد ميلاد الشيخ مجيب الرحمن"

#. Independence Day.
msgid "স্বাধীনতা দিবস"
msgstr "عيد الاستقلال"

#. Bengali New Year's Day.
msgid "পহেলা বৈশাখ"
msgstr "رأس السنة البنغالية"

#. May Day.
msgid "মে দিবস"
msgstr "الأول من مايو"

#. National Mourning Day.
msgid "জাতীয় শোক দিবস"
msgstr "اليوم الوطني للحداد"

#. Victory Day.
msgid "বিজয় দিবস"
msgstr "عيد النصر"
