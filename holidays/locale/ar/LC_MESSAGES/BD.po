#. %s (estimated).
#, c-format
msgid "%s (আনুমানিক)"
msgstr "%s (المقدرة)"

#. Martyrs' Day and International Mother Language Day.
msgid "শহীদ দিবস ও আন্তর্জাতিক মাতৃভাষা দিবস"
msgstr "يوم الشهداء واليوم الدولي للغة الأم"

#. Sheikh Mujibur Rahman's Birthday.
msgid "জাতির পিতা বঙ্গবন্ধু শেখ মুজিবুর রহমান এর জন্মদিবস"
msgstr "عيد ميلاد الشيخ مجيب الرحمن"

#. Independence Day.
msgid "স্বাধীনতা দিবস"
msgstr "عيد الاستقلال"

#. Bengali New Year's Day.
msgid "পহেলা বৈশাখ"
msgstr "رأس السنة البنغالية"

#. May Day.
msgid "মে দিবস"
msgstr "الأول من مايو"

#. July Mass Uprising Day.
msgid "জুলাই গণ-অভ্যুত্থান দিবস"
msgstr "يوم الانتفاضة الشعبية في يوليو"

#. National Mourning Day.
msgid "জাতীয় শোক দিবস"
msgstr "اليوم الوطني للحداد"

#. Victory Day.
msgid "বিজয় দিবস"
msgstr "عيد النصر"

#. Christmas Day.
msgid "বড়দিন"
msgstr "عيد الميلاد"

#. Ashura.
msgid "আশুরা"
msgstr "عاشوراء"

#. Prophet's Birthday.
msgid "ঈদে মিলাদুন্নবী"
msgstr "المولد النبوي الشريف"

#. Mid-Sha'ban.
msgid "শবে বরাত"
msgstr "ليلة النصف من شعبان"

#. Laylat al-Qadr.
msgid "শবে কদর"
msgstr "ليلة القدر"

#. Jumu'atul-Wida.
msgid "জুমাতুল বিদা"
msgstr "جمعة الوداع"

#. Eid al-Fitr.
msgid "ঈদুল ফিতর"
msgstr "عيد الفطر"

#. Eid al-Adha.
msgid "ঈদুল আজহা"
msgstr "عيد الأضحى"
