#. %s (estimated).
#, c-format
msgid "%s (estimated)"
msgstr "%s (estimated)"

#. Birth Anniversary of His Majesty the King.
msgid "Birth Anniversary of His Majesty the King"
msgstr "དཔལ་འབྱོར་མི་དབང་མཆོག་གི་སྐུ་འཁྲུངས་དུས་ཆེན།"

#. Birth Anniversary of the 3rd Druk Gyalpo.
msgid "Birth Anniversary of the 3rd Druk Gyalpo"
msgstr "འབྲུག་རྒྱལ་པོ་གསུམ་པའི་སྐུ་འཁྲུངས་དུས་ཆེན།"

#. Coronation of His Majesty the King.
msgid "Coronation of His Majesty the King"
msgstr "དཔལ་འབྱོར་མི་དབང་མཆོག་གི་ཁྲི་འཛིན་དུས་ཆེན།"

#. Birth Anniversary of the 4th Druk Gyalpo - Constitution Day.
msgid "Birth Anniversary of the 4th Druk Gyalpo - Constitution Day"
msgstr "འབྲུག་རྒྱལ་པོ་བཞི་པའི་སྐུ་འཁྲུངས་དུས་ཆེན་ - རྒྱལ་ཁབ་ཀྱི་ཁྲིམས་ཆེན་ཉིན།"

#. National Day.
msgid "National Day"
msgstr "རྒྱལ་ཡོངས་ཉིན།"

#. Winter Solstice.
msgid "Winter Solstice"
msgstr "དགུན་ཉི་སྒྲོན།"

#. Traditional Day of Offering.
msgid "Traditional Day of Offering"
msgstr "མཆོད་པའི་ཉིན།"

#. Losar.
msgid "Losar"
msgstr "ལོ་གསར།"

#. Death Anniversary of Zhabdrung.
msgid "Death Anniversary of Zhabdrung"
msgstr "ཞབས་དྲུང་གི་དགའ་འཁོར་དུས་ཆེན།"

#. Lord Buddha's Parinirvana.
msgid "Lord Buddha's Parinirvana"
msgstr "སངས་རྒྱས་ཀྱི་མྱང་འདས།"

#. Birth Anniversary of Guru Rinpoche.
msgid "Birth Anniversary of Guru Rinpoche"
msgstr "གུ་རུ་རིན་པོ་ཆེའི་སྐུ་འཁྲུངས་དུས་ཆེན།"

#. First Sermon of Lord Buddha.
msgid "First Sermon of Lord Buddha"
msgstr "སངས་རྒྱས་ཀྱི་ཆོས་སྟོན་དང་པོ།"

#. Blessed Rainy Day.
msgid "Blessed Rainy Day"
msgstr "བསྟན་པའི་ཆར་ཉིན།"

#. Dassain.
msgid "Dassain"
msgstr "ད་ཤེན།"

#. Descending Day of Lord Buddha.
msgid "Descending Day of Lord Buddha"
msgstr "སངས་རྒྱས་ཀྱི་མར་བབས་ཉིན།"

#. Thimphu Drubchoe.
msgid "Thimphu Drubchoe"
msgstr "ཐིམ་ཕུ་དྲུབ་ཆོས།"

#. Thimphu Tshechu.
msgid "Thimphu Tshechu"
msgstr "ཐིམ་ཕུ་ཚེས་བཅུ།"