#. %s (estimated).
#, c-format
msgid "%s (تقديري)"
msgstr "%s (আনুমানিক)"

#. %s (observed).
#, c-format
msgid "%s (يوم تعويضي)"
msgstr "%s (পালিত)"

#. %s (observed, estimated).
#, c-format
msgid "%s (يوم تعويضي تقديري)"
msgstr "%s (পালিত, আনুমানিক)"

#. Eid al-Fitr Holiday.
msgid "عطلة عيد الفطر"
msgstr "ঈদুল ফিতরের ছুটি"

#. Arafat Day.
msgid "يوم عرفة"
msgstr "আরাফাত দিবস"

#. Eid al-Adha Holiday.
msgid "عطلة عيد الأضحى"
msgstr "ঈদুল আযহার ছুটি"

#. Founding Day.
msgid "يوم التأسيسي"
msgstr "প্রতিষ্ঠা দিবস"

#. National Day.
msgid "اليوم الوطني"
msgstr "জাতীয় দিবস"

#. King Abdullah's Return from Medical Treatment Abroad.
msgid "عطلة رسمية بمناسبة عودة الملك عبد الله"
msgstr "রাজা আবদুল্লাহর প্রত্যাবর্তন উপলক্ষে সরকারি ছুটি"

#. Day of Mourning for King Abdullah.
msgid "يوم حداد على الملك عبد الله"
msgstr "রাজা আবদুল্লাহর জন্য শোক দিবস"

#. Holiday for the National Team's Victory in the World Cup.
msgid "عطلة فوز المنتخب في كأس العالم"
msgstr "বিশ্বকাপে জাতীয় দলের জয়ের ছুটি"
