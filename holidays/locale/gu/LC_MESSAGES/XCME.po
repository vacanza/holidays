#. New Year's Day.
msgid "New Year's Day"
msgstr "નવા વર્ષનો દિવસ"

#. Good Friday.
msgid "Good Friday"
msgstr "ગુડ ફ્રાઇડે"

#. Independence Day.
msgid "Independence Day"
msgstr "સ્વતંત્રતા દિવસ"

#. Thanksgiving Day.
msgid "Thanksgiving Day"
msgstr "થેંક્સગિવિંગ ડે"

#. Christmas Day.
msgid "Christmas Day"
msgstr "નાતાલ"

#. %s (markets pause at 10:30am CT)
#, c-format
msgid "%s (markets pause at 10:30am CT)"
msgstr "%s (બજારો સવારે 10:30 વાગ્યે CT સમયે થોભે છે)"

#. %s (markets pause at 12:00pm CT)
#, c-format
msgid "%s (markets pause at 12:00pm CT)"
msgstr "%s (બજારો બપોરે 12:00 વાગ્યે CT સમયે થોભે છે)"

#. Dr. Martin Luther King, Jr. Day.
msgid "Dr. Martin Luther King, Jr. Day"
msgstr "ડૉ. માર્ટિન લ્યુથર કિંગ, જુનિયર ડે"

#. President's Day.
msgid "President's Day"
msgstr "પ્રેસિડેન્ટ્સ ડે"

#. Memorial Day.
msgid "Memorial Day"
msgstr "મેમોરિયલ ડે"

#. Juneteenth Day.
msgid "Juneteenth Day"
msgstr "જુનટીન્થ ડે"

#. Day before Independence Day.
msgid "Day before Independence Day"
msgstr "સ્વતંત્રતા દિવસનો આગલો દિવસ"

#. Labor Day.
msgid "Labor Day"
msgstr "મજૂર દિવસ"

#. Day after Thanksgiving Day.
msgid "Day after Thanksgiving Day"
msgstr "થેંક્સગિવિંગ ડે પછીનો દિવસ"

#. Christmas Eve.
msgid "Christmas Eve"
msgstr "નાતાલ પૂર્વસંધ્યા"

#. Closed following Attacks on the World Trade Center.
msgid "Closed following Attacks on the World Trade Center"
msgstr "વર્લ્ડ ટ્રેડ સેન્ટર પરના હુમલા બાદ બંધ"

#. Hurricane Sandy.
msgid "Hurricane Sandy"
msgstr "હરિકેન સેન્ડી"

#. National Day of Mourning for former President Ronald Reagan.
msgid "National Day of Mourning for former President Ronald Reagan"
msgstr "ભૂતપૂર્વ રાષ્ટ્રપતિ રોનાલ્ડ રેગન માટે રાષ્ટ્રીય શોક દિવસ"

#. National Day of Mourning for former President Gerald R. Ford.
msgid "National Day of Mourning for former President Gerald R. Ford"
msgstr "ભૂતપૂર્વ રાષ્ટ્રપતિ ગેરાલ્ડ આર. ફોર્ડ માટે રાષ્ટ્રીય શોક દિવસ"

#. National Day of Mourning for former President George H. W. Bush.
msgid "National Day of Mourning for former President George H. W. Bush"
msgstr "ભૂતપૂર્વ રાષ્ટ્રપતિ જ્યોર્જ એચ. ડબ્લ્યુ. બુશ માટે રાષ્ટ્રીય શોક દિવસ"

#. National Day of Mourning for former President Jimmy Carter.
msgid "National Day of Mourning for former President Jimmy Carter"
msgstr "ભૂતપૂર્વ રાષ્ટ્રપતિ જિમી કાર્ટર માટે રાષ્ટ્રીય શોક દિવસ"
