#. %s (estimated).
#, c-format
msgid "%s（推定）"
msgstr "%s（推定）"

#. %s (observed, estimated).
#, c-format
msgid "%s（观察日，推定）"
msgstr "%s（观察日，推定）"

#. %s (observed).
#, c-format
msgid "%s（观察日）"
msgstr "%s（观察日）"

#. New Year's Day.
msgid "元旦"
msgstr "元旦"

#. Chinese New Year (Spring Festival).
msgid "春节"
msgstr "春节"

#. Chinese New Year's Eve.
msgid "农历除夕"
msgstr "农历除夕"

#. Labor Day.
msgid "劳动节"
msgstr "劳动节"

#. National Day.
msgid "国庆节"
msgstr "国庆节"

#. Tomb-Sweeping Day.
msgid "清明节"
msgstr "清明节"

#. Dragon Boat Festival.
msgid "端午节"
msgstr "端午节"

#. Mid-Autumn Festival.
msgid "中秋节"
msgstr "中秋节"

#. International Women's Day.
msgid "国际妇女节"
msgstr "国际妇女节"

#. Youth Day.
msgid "五四青年节"
msgstr "五四青年节"

#. Children's Day.
msgid "六一儿童节"
msgstr "六一儿童节"

#. Army Day.
msgid "建军节"
msgstr "建军节"

#. Date format (see strftime() Format Codes).
msgid "%Y-%m-%d"
msgstr "%Y-%m-%d"

#. Day off (substituted from %s).
#, c-format
msgid "休息日（%s日起取代）"
msgstr "休息日（%s日起取代）"

#. Chinese New Year (Spring Festival) Extended Holiday.
msgid "春节延长假期"
msgstr "春节延长假期"

