#. %s (estimated).
#, c-format
msgid "%s (taxminiy)"
msgstr "%s (приблизна дата)"

#. %s (observed).
#, c-format
msgid "%s (koʻchirilgan)"
msgstr "%s (вихідний)"

#. %s (observed, estimated).
#, c-format
msgid "%s (koʻchirilgan, taxminiy)"
msgstr "%s (вихідний, приблизна дата)"

#. New Year's Day.
msgid "Yangi yil"
msgstr "Новий рік"

#. Women's Day.
msgid "Xotin-qizlar kuni"
msgstr "Жіночий день"

#. Nowruz.
msgid "Navroʻz bayrami"
msgstr "Свято Новруз"

#. Day of Memory and Honor.
msgid "Xotira va qadrlash kuni"
msgstr "День памʼяті і шани"

#. Victory Day.
msgid "Gʻalaba kuni"
msgstr "День Перемоги"

#. Independence Day.
msgid "Mustaqillik kuni"
msgstr "День незалежності"

#. Teachers and Instructors Day.
msgid "Oʻqituvchi va murabbiylar kuni"
msgstr "День вчителя і наставника"

#. Constitution Day.
msgid "Oʻzbekiston Respublikasi Konstitutsiyasi kuni"
msgstr "День Конституції Республіки Узбекистан"

#. Eid al-Fitr.
msgid "Roʻza hayit"
msgstr "Рамазан-байрам"

#. Eid al-Adha.
msgid "Qurbon hayit"
msgstr "Курбан-байрам"

#. Date format (see strftime() Format Codes)
msgid "%d/%m %Y"
msgstr "%d.%m.%Y"

#. Day off (substituted from %s).
#, c-format
msgid "Dam olish kuni (%s dan koʻchirilgan)"
msgstr "Вихідний день (перенесено з %s)"

#. Additional day off by Presidential decree.
msgid "Prezidentining farmoni bilan qoʻshimcha dam olish kuni"
msgstr "Додатковий вихідний згідно указу Президента"
