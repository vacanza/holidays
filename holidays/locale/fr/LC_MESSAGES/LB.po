#. %s (estimated).
#, c-format
msgid "%s (المقدرة)"
msgstr "%s (estimé)"

#. %s (observed).
#, c-format
msgid "%s (يُحتفل به)"
msgstr "%s (observé)"

#. %s (observed, estimated).
#, c-format
msgid "%s (يُحتفل به، المقدرة)"
msgstr "%s (observé, estimé)"

#. New Year's Day.
msgid "رأس السنة الميلادية"
msgstr "Nouvel An"

#. Armenian Orthodox Christmas Day.
msgid "عيد الميلاد عند الطوائف الارمنية الارثوذكسية"
msgstr "Noël Arménien"

#. Saint Maron's Day.
msgid "عيد مار مارون"
msgstr "Saint Maron"

#. Feast of the Annunciation.
msgid "عيد بشارة السيدة مريم العذراء"
msgstr "Annonciation"

#. Catholic Good Friday.
msgid "الجمعة العظيمة عند الطوائف الكاثوليكية"
msgstr "Vendredi Saint Catholique"

#. Orthodox Good Friday.
msgid "الجمعة العظيمة عند الطوائف الأرثوذكسية"
msgstr "Vendredi Saint Orthodoxe"

#. Orthodox Holy Saturday.
msgid "سبت النور للطائفة الأرثوذكسية"
